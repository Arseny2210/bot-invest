# =============================================================================
# MOEX AI Analyst — environment configuration
#
# Copy to `.env` and fill in secrets. Nested settings use the `__` delimiter
# (e.g. DB__HOST maps to settings.db.host). Booleans accept true/false/1/0.
# NEVER commit the real `.env` — only this template is tracked.
# =============================================================================

# --- Application -------------------------------------------------------------
# environment: local | dev | prod | test
ENVIRONMENT=local
# log_level: TRACE | DEBUG | INFO | SUCCESS | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Emit one JSON object per line (enable in prod for log shippers).
LOG_SERIALIZE=false
# Loguru variable interpolation in tracebacks. MUST stay false in prod:
# `true` can leak secret values into exception frames.
LOG_DIAGNOSE=false

# --- Telegram bot ------------------------------------------------------------
BOT__TOKEN=123456:replace-with-real-bot-token
# Polling (false) for local dev; webhook (true) for production.
BOT__USE_WEBHOOK=false
# Required when BOT__USE_WEBHOOK=true. Public HTTPS base, no trailing slash.
BOT__WEBHOOK_BASE_URL=
BOT__WEBHOOK_PATH=/telegram/webhook
# Required when BOT__USE_WEBHOOK=true. Verified against the
# X-Telegram-Bot-Api-Secret-Token header on every incoming update.
BOT__WEBHOOK_SECRET=
# Per-user anti-spam budget for interactive commands.
BOT__RATE_LIMIT_PER_MINUTE=20

# --- PostgreSQL --------------------------------------------------------------
DB__HOST=localhost
DB__PORT=5432
DB__USER=moex
DB__PASSWORD=change-me
DB__NAME=moex_analyst
DB__POOL_SIZE=10
DB__MAX_OVERFLOW=5
DB__POOL_TIMEOUT=30
DB__ECHO=false

# --- Redis -------------------------------------------------------------------
REDIS__HOST=localhost
REDIS__PORT=6379
# Leave empty if Redis has no password (local dev).
REDIS__PASSWORD=
# Logical DBs are isolated by concern.
REDIS__CACHE_DB=0
REDIS__FSM_DB=1

# --- MOEX ISS API ------------------------------------------------------------
MOEX__BASE_URL=https://iss.moex.com/iss
MOEX__REQUEST_TIMEOUT=10.0
MOEX__CONNECT_TIMEOUT=5.0
MOEX__MAX_RETRIES=4
MOEX__BACKOFF_BASE=0.5
# Token-bucket limiter protecting ISS from request bursts.
MOEX__RATE_LIMIT_RPS=5.0
MOEX__RATE_LIMIT_BURST=10
MOEX__USER_AGENT=moex-ai-analyst/0.1
